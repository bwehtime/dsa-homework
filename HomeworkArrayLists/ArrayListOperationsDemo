import java.util.*;

public class ArrayListOperationsDemo {

    public static void main(String args[]){
        arrayToArrayListDemo();
        arrayListToArrayDemo();
        subListDemo();
        arrayListSorting();
        arrayListSearching();
    }

    public static void arrayToArrayListDemo(){
        Student[] studentObjects = {new Student(), new Student(), new Student()};
        ArrayList<Student> students = new ArrayList<>(Arrays.asList(studentObjects));

        for (int i = 0; i < studentObjects.length; i++){
            System.out.println(studentObjects[i]);
        }

        System.out.println();

        students.add(new Student());
        students.add(new Student());

        for (Student student : students){
            System.out.println(student);
        }

        System.out.println();

        students.remove(0);
        students.remove(0);

        for (Student student : students){
            System.out.println(student);
        }

    }

    public static void arrayListToArrayDemo(){
        ArrayList<Student> students = new ArrayList<>();
        students.add(new Student());
        students.add(new Student());
        students.add(new Student());

        Student[] studentArray = students.toArray(new Student[0]);

        System.out.println(students);
        for (Student student: studentArray) {
            System.out.println(student);
        }
    }

    public static void subListDemo(){
        ArrayList<Student> students = new ArrayList<>();
        students.add(new Student("00368", "Jessica", "Newton", "jnewton@gmail.com", 3.7, "Physics", 2));
        students.add(new Student("23369", "Riley", "Ren", "rren@gmail.com", 2.8, "History", 1));
        students.add(new Student("21355", "Flora", "Simons", "fsimons@gmail.com", 3.9, "Computer Science", 3));

        List<Student> studentSub = students.subList(1,2);

        System.out.println("ArrayList: ");
        System.out.println(students);
        System.out.println();

        System.out.println("SubList: ");
        System.out.println(studentSub);
        System.out.println();

        studentSub.add(new Student());
        System.out.println("New Student Added to SubList.");

        System.out.println("ArrayList: ");
        System.out.println(students);
        System.out.println();

        System.out.println("SubList: ");
        System.out.println(studentSub);
        System.out.println();

        studentSub.remove(1);
        System.out.println("Student Removed from SubList.");

        System.out.println("ArrayList: ");
        System.out.println(students);
        System.out.println();

        System.out.println("SubList: ");
        System.out.println(studentSub);
        System.out.println();
    }

    public static void arrayListSorting(){
        ArrayList<Student> students = new ArrayList<>();
        students.add(new Student("00368", "Jessica", "Newton", "jnewton@gmail.com", 3.7, "Physics", 2));
        students.add(new Student("23369", "Riley", "Ren", "rren@gmail.com", 2.8, "History", 1));
        students.add(new Student("21355", "Flora", "Simons", "fsimons@gmail.com", 3.9, "Computer Science", 3));
        System.out.println(students);

        Collections.sort(students, Comparator.comparingDouble(Student::getGpa));

        System.out.println(students);

        Collections.sort(students, Comparator.comparing(Student::getLastName));
        System.out.println(students);
    }

